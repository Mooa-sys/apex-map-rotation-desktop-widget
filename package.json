{
  "name": "apex-mapchange",
  "version": "1.4.0",
  "description": "A small Windows desktop widget for Apex Legends ranked map rotation.",
  "license": "MIT",
  "main": "out/main/index.js",
  "type": "module",
  "scripts": {
    "dev": "electron-vite dev",
    "generate:icon": "node scripts/generate-icon.mjs",
    "build": "npm run typecheck && electron-vite build",
    "typecheck": "tsc --noEmit",
    "package:win": "npm run generate:icon && npm run build && electron-builder --win dir",
    "package:portable": "npm run generate:icon && npm run build && electron-builder --win portable"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "electron": "^33.2.1",
    "electron-builder": "^25.1.8",
    "electron-vite": "^2.3.0",
    "gsap": "^3.15.0",
    "lucide-react": "^0.468.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "svg-to-ico": "^1.1.1",
    "typescript": "^5.9.2",
    "vite": "^5.4.11"
  },
  "build": {
    "appId": "com.apexmapchange.widget",
    "productName": "Apex map",
    "artifactName": "Apex map.${ext}",
    "directories": {
      "output": "release"
    },
    "files": [
      "out/**/*",
      "package.json"
    ],
    "win": {
      "icon": "build/icon.ico",
      "target": "portable"
    }
  }
}
